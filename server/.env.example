# PPF CTA/Contact API (file-based CTAs + admin auth)
PORT=3001
PPF_DATA_DIR=./data

# Admin login (required for PUT /api/ctas). Server-side only — never exposed to frontend.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password

# JWT secret for admin session cookie. Use a long random string in production.
JWT_SECRET=your-jwt-secret-min-32-chars

# In production, set to your frontend origin (e.g. https://pakpalforum.com) for CORS.
# CORS_ORIGIN=https://pakpalforum.com
