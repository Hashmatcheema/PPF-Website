# --- Frontend (Vite) ---
# Leave empty on Vercel: the app calls same-origin `/api/*` (serverless + static).
# Local API: run `vercel dev` from this folder (Upstash vars in `.env.local`), keep this empty
# and optionally set VITE_DEV_API_PROXY to that URL (default http://127.0.0.1:3000).
VITE_CTAS_API_URL=

# Pure static demo: no /api; CTAs in localStorage; insecure client-only admin (VITE_ADMIN_*).
# VITE_NO_API=1

# Only when VITE_NO_API=1 — never use in production
# VITE_ADMIN_USERNAME=
# VITE_ADMIN_PASSWORD=

# --- Vercel / `vercel dev` (Project → Settings → Environment Variables or `.env.local`) ---
# Upstash: optional for local admin login + GET /api/ctas (uses in-memory defaults, no rate limits).
# Required to persist CTAs, contact form, and rate limits in production.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# JWT_SECRET=
# Server admin login (/api/admin/login) — required on production; for `vercel dev` you can use either these or VITE_ADMIN_* below.
# ADMIN_USERNAME=
# ADMIN_PASSWORD=
# Optional: ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
