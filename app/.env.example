# PPF Frontend — set before build (e.g. in CI or .env.production)
# Leave empty to use bundled CTA defaults and localStorage for admin CTAs.

# Backend API URL. When set, admin login uses server-side auth (cookie); CTAs are read/written via API.
VITE_CTAS_API_URL=http://localhost:3001

# Only for local dev when VITE_CTAS_API_URL is empty: client-side admin login (not secure; do not use in production).
# VITE_ADMIN_USERNAME=admin
# VITE_ADMIN_PASSWORD=dev-only-password
