# --- Frontend (Vite) ---
# Leave empty on Vercel: the app calls same-origin `/api/*` (serverless + static).
# For local Express API on port 3001:  VITE_CTAS_API_URL=http://localhost:3001
# Optional: proxy /api from Vite to vercel dev (default http://127.0.0.1:3000):
#   VITE_DEV_API_PROXY=http://127.0.0.1:3000
VITE_CTAS_API_URL=

# Pure static demo: no /api calls; CTAs in localStorage; insecure client-only admin (VITE_ADMIN_*).
# VITE_NO_API=1

# Only when VITE_NO_API=1 — never use in production
# VITE_ADMIN_USERNAME=
# VITE_ADMIN_PASSWORD=

# --- Vercel serverless (Project → Settings → Environment Variables) ---
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# JWT_SECRET=         # long random string (32+ chars)
# ADMIN_USERNAME=
# ADMIN_PASSWORD=
# Optional: extra allowed Origins for dev (comma-separated). Same-host requests always allowed.
# ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
